<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <add value="index.html" />
      </files>
    </defaultDocument>
    
    <!-- Cache Control Rules -->
    <staticContent>
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>
    
    <!-- Custom Headers for Cache Control -->
    <httpProtocol>
      <customHeaders>
        <!-- Disable caching for index.html -->
        <add name="Cache-Control" value="no-store, must-revalidate" />
      </customHeaders>
    </httpProtocol>
    
    <!-- Outbound Rules for specific files -->
    <rewrite>
      <rules>
        <rule name="ReactRouter" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
      
      <outboundRules>
        <!-- No cache for index.html -->
        <rule name="NoCacheIndexHtml" preCondition="IsIndexHtml">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, must-revalidate" />
        </rule>
        
        <!-- Long cache for hashed assets -->
        <rule name="LongCacheAssets" preCondition="IsHashedAsset">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="max-age=31536000, immutable" />
        </rule>
        
        <preConditions>
          <preCondition name="IsIndexHtml">
            <add input="{REQUEST_URI}" pattern="index\.html$" />
          </preCondition>
          <preCondition name="IsHashedAsset">
            <add input="{REQUEST_URI}" pattern="\.(js|css|svg|png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot)$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
    
    <!-- Caching Profiles -->
    <caching>
      <profiles>
        <add extension=".js" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".css" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".svg" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".png" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".jpg" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".jpeg" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".gif" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".ico" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".woff" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".woff2" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".ttf" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
        <add extension=".eot" policy="CacheForTimePeriod" duration="365.00:00:00" kernelCachePolicy="CacheUntilChange" />
      </profiles>
    </caching>
  </system.webServer>
</configuration>
